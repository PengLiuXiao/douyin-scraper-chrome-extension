{
  "manifest_version": 3,
  "name": "DouyinURL提取Pro",
  "version": "1.2.0",
  "description": "AI智能检测抖音视频数据，一键提取视频链接、视频ID等12个数据字段，支持CSV/XLSX导出",
  "permissions": [
    "webRequest",
    "activeTab",
    "storage",
    "clipboardWrite",
    "notifications",
    "scripting",
    "sidePanel",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "*://*.douyin.com/*"
  ],
  "action": {
    "default_title": "DouyinURL提取Pro - AI智能检测"
  },
  "side_panel": {
    "default_path": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.douyin.com/*"],
      "js": ["src/content/inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.douyin.com/*"],
      "js": ["lib/jquery-3.1.1.min.js", "lib/sha256.min.js", "src/content/content.js"],
      "css": ["src/content/content.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png", 
    "128": "assets/icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background/background.js"
  }
}